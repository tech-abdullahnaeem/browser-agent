# === Required ===
GEMINI_API_KEY=your-gemini-api-key-here

# === Browser Settings ===
# Path to an existing Chrome user data directory to inherit logins/cookies.
# Leave empty for a fresh temporary profile each run.
BROWSER_USER_DATA_DIR=
HEADLESS=false

# === Agent Settings ===
MAX_STEPS=50
MAX_FAILURES=5
USE_VISION=true
WAIT_BETWEEN_ACTIONS=0.5

# === Logging ===
LOG_LEVEL=INFO
